#!name=自动签到
#!desc=NGA / V2EX / IT之家 自动签到
#!author=Mikukko[https://github.com/mikukko]
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Panda.png
#!homepage=https://github.com/mikukko/surge-conf
#!category=Mikukko
#!date=2025-07-07 00:00:00
#!arguments=签到时间:10 0 * * *,NGA签到:NGA签到,V2EX签到:V2EX签到,IT之家签到:IT之家签到
#!arguments-desc=签到时间\n- Cron 表达式，默认每天 0:10\n- 示例: 0 9 * * * (每天9点)\n\nNGA签到\n- NGA签到: 开启\n- #: 关闭\n\nV2EX签到\n- V2EX签到: 开启\n- #: 关闭\n\nIT之家签到\n- IT之家签到: 开启\n- #: 关闭

[Script]
# NGA Cookie 获取
NGA Cookie = type=http-request, pattern=^https:\/\/ngabbs\.com\/nuke.php\??, script-path=https://raw.githubusercontent.com/mikukko/surge-conf/master/scripts/nga_cookie.js, requires-body=true
# NGA 每日签到
{{{NGA签到}}} = type=cron, cronexp={{{签到时间}}}, script-path=https://raw.githubusercontent.com/mikukko/surge-conf/master/scripts/nga.js, wake-system=true

# V2EX Cookie 获取
V2EX Cookie = type=http-request, pattern=^https:\/\/www\.v2ex\.com\/mission\/daily$, script-path=https://raw.githubusercontent.com/mikukko/surge-conf/master/scripts/v2ex_cookie.js
# V2EX 每日签到
{{{V2EX签到}}} = type=cron, cronexp={{{签到时间}}}, script-path=https://raw.githubusercontent.com/mikukko/surge-conf/master/scripts/v2ex.js, wake-system=true

# IT之家 Cookie 获取
IT之家 Cookie = type=http-request, pattern=^https:\/\/napi\.ithome\.com\/api\/usersign\/getsigninfo, script-path=https://raw.githubusercontent.com/mikukko/surge-conf/master/scripts/ithome_cookie.js
# IT之家 每日签到
{{{IT之家签到}}} = type=cron, cronexp={{{签到时间}}}, script-path=https://raw.githubusercontent.com/mikukko/surge-conf/master/scripts/ithome.js, wake-system=true

[MITM]
hostname = %APPEND% ngabbs.com, www.v2ex.com, napi.ithome.com
