#!name=自动签到
#!desc=NGA / V2EX / IT之家 自动签到
#!author=Mikukko[https://github.com/mikukko]
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Panda.png
#!homepage=https://github.com/mikukko/surge-conf
#!category=Mikukko
#!date=2026-06-27 00:00:00
#!arguments=NGA 签到:nga.sign,NGA cron:10 0 * * *,V2EX 签到:v2ex.sign,V2EX cron:5 8 * * *,IT之家 签到:ithome.sign,IT之家 cron:10 0 * * *
#!arguments-desc=NGA 签到: 填 # 关闭\n\nNGA cron\n- 默认每天 0:10\n- 仅作用于 NGA 签到\n\nV2EX 签到: 填 # 关闭\n\nV2EX cron\n- 默认每天 8:05\n- 仅作用于 V2EX 签到\n\nIT之家 签到: 填 # 关闭\n\nIT之家 cron\n- 默认每天 0:10\n- 仅作用于 IT之家 签到

[Script]
# NGA Cookie 获取
NGA Cookie = type=http-request, pattern=^https:\/\/ngabbs\.com\/nuke.php\??, script-path=https://raw.githubusercontent.com/mikukko/surge-conf/master/scripts/nga_cookie.js, requires-body=true
# NGA 每日签到
{{{NGA 签到}}} = type=cron, cronexp={{{NGA cron}}}, script-path=https://raw.githubusercontent.com/mikukko/surge-conf/master/scripts/nga.js, wake-system=true

# V2EX Cookie 获取
V2EX Cookie = type=http-request, pattern=^https:\/\/www\.v2ex\.com\/mission\/daily$, script-path=https://raw.githubusercontent.com/mikukko/surge-conf/master/scripts/v2ex_cookie.js
# V2EX 每日签到
{{{V2EX 签到}}} = type=cron, cronexp={{{V2EX cron}}}, script-path=https://raw.githubusercontent.com/mikukko/surge-conf/master/scripts/v2ex.js, wake-system=true

# IT之家 Cookie 获取
IT之家 Cookie = type=http-request, pattern=^https:\/\/napi\.ithome\.com\/api\/usersign\/getsigninfo, script-path=https://raw.githubusercontent.com/mikukko/surge-conf/master/scripts/ithome_cookie.js
# IT之家 每日签到
{{{IT之家 签到}}} = type=cron, cronexp={{{IT之家 cron}}}, script-path=https://raw.githubusercontent.com/mikukko/surge-conf/master/scripts/ithome.js, wake-system=true

[MITM]
hostname = %APPEND% ngabbs.com, www.v2ex.com, napi.ithome.com
